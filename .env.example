# ─────────────────────────────────────────────
#  deception-lab/.env.example
#  Template file for environment variables.
#  Copy this file to .env and configure keys.
# ─────────────────────────────────────────────

# Elasticsearch superuser password
ELASTIC_PASSWORD=your_elastic_password_here

# Kibana system user password (must match what you set in Elasticsearch)
KIBANA_PASSWORD=your_kibana_password_here

# Kibana encryption key — must be at least 32 chars
KIBANA_ENCRYPTION_KEY=a1b2c3d4e5f6a1b2c3d4e5f6a1b2c3d4e5f6

# ── Threat Intelligence API Keys ──────────────
# Get free keys from:
# AbuseIPDB:   https://www.abuseipdb.com/account/api
# VirusTotal:  https://www.virustotal.com/gui/my-apikey
# OTX:         https://otx.alienvault.com/api

ABUSEIPDB_API_KEY=your_abuseipdb_key_here
VIRUSTOTAL_API_KEY=your_virustotal_key_here
OTX_API_KEY=your_otx_key_here
